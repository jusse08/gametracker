# GameTracker Environment Variables

# ===========================================
# BACKEND (.env в папке backend/)
# ===========================================

# Database URL (SQLite)
DATABASE_URL=sqlite:///./database.db

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated)
# Для локальной разработки:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# Для Docker:
# ALLOWED_ORIGINS=http://localhost,http://your-server-ip

# Steam API Key (получить на https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# ===========================================
# FRONTEND (.env в папке frontend/)
# ===========================================

# API Base URL
# Для локальной разработки:
VITE_API_BASE=http://127.0.0.1:8000/api
# Для Docker:
# VITE_API_BASE=http://localhost:8000/api
# Для Caddy/proxy:
# VITE_API_BASE=/api

# ===========================================
# DOCKER COMPOSE (.env в корне проекта)
# ===========================================

# Для docker-compose.yml
# ALLOWED_ORIGINS=http://localhost,http://your-server-ip

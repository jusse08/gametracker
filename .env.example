# GameTracker root .env

# Runtime ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend runtime
BACKEND_HOST=0.0.0.0
DATABASE_URL=sqlite:///./data/database.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESS_TOKEN_EXPIRE_MINUTES=10080
LOG_LEVEL=WARNING
UVICORN_LOG_LEVEL=warning
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AGENT_PENDING_LAUNCH_TTL_SECONDS=180
# Optional: comma/semicolon separated absolute Windows roots allowed for agent launch paths.
# Example: AGENT_ALLOWED_LAUNCH_ROOTS=C:\\Games;D:\\Launchers
AGENT_ALLOWED_LAUNCH_ROOTS=

# Frontend build/runtime
VITE_API_BASE=http://localhost:8000/api

# Superadmin bootstrap
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=REPLACE_WITH_A_STRONG_SUPERADMIN_PASSWORD

# JWT signing key (must be long random value in production)
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY
